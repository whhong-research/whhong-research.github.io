&lt;h2 id=&#34;维护流程&#34;&gt;维护流程
&lt;/h2&gt;&lt;p&gt;维护流程的时间节点定义：&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;阶段&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;代号&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;描述&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;故障检测到修复指令&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M1&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;从检测到故障到发出修复指令的时间&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;维修计划会议&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M2&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;安排会议来制定维修计划的时间&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;计划制定&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M3&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;制定详细维修计划的时间&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;资源准备&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M4+M5&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;租用船只、调遣人员、准备维护设备的时间&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;备件调用&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M6&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;如果有备件，启用备件的时间（远短于M5）&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;出发准备&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M7&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;维护船准备出发&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;运输到场&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M8/M9&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;运输船到达现场的时间，M9考虑了天气因素（等待合适窗口期）&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;维修实施&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;M11&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;维护作业所需的时间&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
