          &lt;td style=&#34;text-align: left&#34;&gt;生命周期历史记录&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;/td&gt;
