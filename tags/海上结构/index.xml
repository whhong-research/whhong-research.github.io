&lt;h1 id=&#34;常见海上结构故障分析&#34;&gt;常见海上结构故障分析
&lt;/h1&gt;&lt;h2 id=&#34;结构极限状态分类&#34;&gt;结构极限状态分类
&lt;/h2&gt;&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;极限状态&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;英文全称&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;定义&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;关注点&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;目标&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;SLS&lt;/strong&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Serviceability Limit State&lt;br&gt;（正常使用极限状态）&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;结构在正常使用条件下应满足的功能要求&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;变形、振动、裂缝宽度等&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;保证结构的功能性和舒适性&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;FLS&lt;/strong&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Fatigue Limit State&lt;br&gt;（疲劳极限状态）&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;结构在反复荷载作用下抵抗疲劳破坏的能力&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;循环应力、疲劳寿命、裂纹扩展等&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;防止结构因反复荷载导致的疲劳破坏&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;ULS&lt;/strong&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Ultimate Limit State&lt;br&gt;（承载能力极限状态）&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;结构在最大荷载作用下抵抗破坏的能力&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;强度、稳定性、整体稳定性等&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;确保结构在极端条件下的安全性，防止倒塌或严重破坏&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;ALS&lt;/strong&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;Accidental Limit State&lt;br&gt;（偶然作用极限状态）&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;结构在偶然事件（如爆炸、撞击、火灾等）下的性能&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;剩余承载力、整体稳定性、局部破坏等&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;保证结构在偶然事件中不发生灾难性破坏，尽量减少损失&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h2 id=&#34;典型结构失效场景&#34;&gt;典型结构失效场景
&lt;/h2&gt;&lt;p&gt;&lt;strong&gt;表5 不同失效场景概述&lt;/strong&gt;&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th style=&#34;text-align: center&#34;&gt;场景编号&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;场景描述&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;1&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;低周和高周疲劳导致的疲劳开裂&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;2&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;HISC（氢致应力开裂）相关开裂&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;3&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;点蚀和腐蚀&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;4&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;甲板上的掉落物冲击&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;6&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;极端载荷导致的屈服超载&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;7&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;极端载荷导致的局部和整体屈曲&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;8&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;极端载荷导致的整体崩塌&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;9&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;局部波浪冲击导致的凹痕&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;10&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;系泊缆或拉索断裂&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;11&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;泄漏导致的进水&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;12&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;异常环境条件的影响（甲板上的波浪）&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;13&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;爆炸&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;漂浮式与固定式结构故障原因对比&#34;&gt;漂浮式与固定式结构故障原因对比
&lt;/h3&gt;&lt;p&gt;从下图可以看出，&lt;strong&gt;疲劳、腐蚀、过载和振动&lt;/strong&gt;是漂浮式结构中主要的故障原因，而固定式结构还包括&lt;strong&gt;基础与海床的相互作用&lt;/strong&gt;以及&lt;strong&gt;平台间的连接桥&lt;/strong&gt;。同时，还需考虑&lt;strong&gt;掉落物体&lt;/strong&gt;以及&lt;strong&gt;船舶撞击&lt;/strong&gt;等因素。&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://whhong-research.github.io/p/%E5%88%A9%E7%94%A8%E4%BC%A0%E6%84%9F%E5%99%A8%E6%95%B0%E6%8D%AE%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E7%BB%93%E6%9E%84%E5%81%A5%E5%BA%B7%E7%9B%91%E6%B5%8Bpsa%E7%A0%94%E7%A9%B6%E6%8A%A5%E5%91%8A%E6%B7%B1%E5%BA%A6%E8%A7%A3%E8%AF%BB/image-20250225151959404.png&#34;
	width=&#34;933&#34;
	height=&#34;738&#34;
	srcset=&#34;https://whhong-research.github.io/p/%E5%88%A9%E7%94%A8%E4%BC%A0%E6%84%9F%E5%99%A8%E6%95%B0%E6%8D%AE%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E7%BB%93%E6%9E%84%E5%81%A5%E5%BA%B7%E7%9B%91%E6%B5%8Bpsa%E7%A0%94%E7%A9%B6%E6%8A%A5%E5%91%8A%E6%B7%B1%E5%BA%A6%E8%A7%A3%E8%AF%BB/image-20250225151959404_hu_6af8bff1b97ee9e9.png 480w, https://whhong-research.github.io/p/%E5%88%A9%E7%94%A8%E4%BC%A0%E6%84%9F%E5%99%A8%E6%95%B0%E6%8D%AE%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E7%BB%93%E6%9E%84%E5%81%A5%E5%BA%B7%E7%9B%91%E6%B5%8Bpsa%E7%A0%94%E7%A9%B6%E6%8A%A5%E5%91%8A%E6%B7%B1%E5%BA%A6%E8%A7%A3%E8%AF%BB/image-20250225151959404_hu_4b88aa16a9301cda.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;海上结构常见结构失效模式及原因&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;126&#34;
		data-flex-basis=&#34;303px&#34;
	
&gt;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;表6：重要失效模式总结&lt;/strong&gt;&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th style=&#34;text-align: center&#34;&gt;失效模式编号&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;描述&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;1&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;由于疲劳和腐蚀导致的（贯穿厚度）开裂&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;2&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;由于疲劳或腐蚀导致的构件分离&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;3&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;由于疲劳或腐蚀导致的构件缺失&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;4&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;由于船舶撞击或掉落物导致的凹痕和变形&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;5&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;固定式安装的灌浆连接（滑移和失效）&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;6&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;固定式安装的超载（沉降和下沉）&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;7&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;固定式安装的冲刷&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;8&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;多种原因导致的过度/意外振动&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;9&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;多种原因导致的桥梁支承问题（互连桥）&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: center&#34;&gt;10&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;由风、波浪或水流作用导致的涡激振动问题&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h2 id=&#34;钢结构常见故障模式&#34;&gt;钢结构常见故障模式
&lt;/h2&gt;&lt;p&gt;钢结构典型的故障模式是&lt;strong&gt;结构承载力的下降&lt;/strong&gt;，造成承载力下降的故障机制包括：&lt;strong&gt;材料退化、材料损失、疲劳和过度负载&lt;/strong&gt;等。导致这些故障机制的主要影响因素如下图所示：&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://whhong-research.github.io/p/%E5%88%A9%E7%94%A8%E4%BC%A0%E6%84%9F%E5%99%A8%E6%95%B0%E6%8D%AE%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E7%BB%93%E6%9E%84%E5%81%A5%E5%BA%B7%E7%9B%91%E6%B5%8Bpsa%E7%A0%94%E7%A9%B6%E6%8A%A5%E5%91%8A%E6%B7%B1%E5%BA%A6%E8%A7%A3%E8%AF%BB/image-20250225153354229.png&#34;
	width=&#34;846&#34;
	height=&#34;594&#34;
	srcset=&#34;https://whhong-research.github.io/p/%E5%88%A9%E7%94%A8%E4%BC%A0%E6%84%9F%E5%99%A8%E6%95%B0%E6%8D%AE%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E7%BB%93%E6%9E%84%E5%81%A5%E5%BA%B7%E7%9B%91%E6%B5%8Bpsa%E7%A0%94%E7%A9%B6%E6%8A%A5%E5%91%8A%E6%B7%B1%E5%BA%A6%E8%A7%A3%E8%AF%BB/image-20250225153354229_hu_710784e51b65d6f5.png 480w, https://whhong-research.github.io/p/%E5%88%A9%E7%94%A8%E4%BC%A0%E6%84%9F%E5%99%A8%E6%95%B0%E6%8D%AE%E8%BF%9B%E8%A1%8C%E6%B5%B7%E4%B8%8A%E7%BB%93%E6%9E%84%E5%81%A5%E5%BA%B7%E7%9B%91%E6%B5%8Bpsa%E7%A0%94%E7%A9%B6%E6%8A%A5%E5%91%8A%E6%B7%B1%E5%BA%A6%E8%A7%A3%E8%AF%BB/image-20250225153354229_hu_7a84bef4b9962136.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;钢结构常见故障模式&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;142&#34;
		data-flex-basis=&#34;341px&#34;
	
&gt;&lt;/p&gt;
&lt;h2 id=&#34;海上结构重大事故报告统计&#34;&gt;海上结构重大事故报告统计
&lt;/h2&gt;&lt;p&gt;下表中总结了过去几年中主要的海上结构管理机构对重大结构性事故的报告统计。&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;表7：过去五年被定义为重大事故的报告事件&lt;/strong&gt;&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;地区&lt;/th&gt;
          &lt;th style=&#34;text-align: left&#34;&gt;报告的事件&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;欧盟&lt;/strong&gt;：海上油气作业安全&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;报告的结构完整性损失事件统计：&lt;br&gt;• 2016年：0起&lt;br&gt;• 2017年：0起&lt;br&gt;• 2018年：0起&lt;br&gt;• 2019年：2起（无法确定具体事件）&lt;br&gt;• 2020年：1起（克罗地亚INA天然气平台完全损失）&lt;br&gt;• 2021年：0起&lt;br&gt;&lt;a class=&#34;link&#34; href=&#34;https://www.croatiaweek.com/inas-missing-gas-platform-found-on-seabed/&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;参考链接&lt;/a&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;英国&lt;/strong&gt;：RIDDOR危险事故报告&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;运营商应报告的事故类型：&lt;br&gt;• &lt;strong&gt;坍塌&lt;/strong&gt;：任何海上设施或设备的非故意坍塌或部分坍塌，危及设施的整体结构完整性&lt;br&gt;• &lt;strong&gt;海床下沉或坍塌&lt;/strong&gt;：任何可能影响海上设施基础或整体结构完整性的海床下沉或坍塌&lt;br&gt;&lt;br&gt;与监管机构的非正式讨论显示，没有上述重大失效的记录。已发生一些失效，但未达到需要报告的程度。&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;IOGP&lt;/strong&gt;&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;未报告重大结构失效事件，非正式反馈表明没有结构失效的情况。&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;美国&lt;/strong&gt;：BSEE海上事故统计&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;搜索2018-2021年的重大事故，仅报告了各种起重机事故，未提及导管架失效，但注意到一些船舶撞击导致的支腿损坏。&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;&lt;strong&gt;澳大利亚&lt;/strong&gt;：NOPSEMA&lt;/td&gt;
          &lt;td style=&#34;text-align: left&#34;&gt;2019-2020年期间没有与结构（和井）完整性相关的监管行动。&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
